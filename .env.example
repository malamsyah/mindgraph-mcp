# mindgraph configuration template.
# Copy to .env and fill in real values for local dev.

# App-level bearer token (32+ chars recommended).
MINDGRAPH_API_KEY=

# Neo4j connection. Use bolt:// for local docker, neo4j+s:// for AuraDB.
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=devpassword

# Voyage AI API key (https://dash.voyageai.com).
VOYAGE_API_KEY=

# Embedding model + dimensions. Must match the vector index DDL.
EMBEDDING_MODEL=voyage-3-large
EMBEDDING_DIMENSIONS=2048

# HTTP listen port.
PORT=8080

# Log verbosity: debug, info, warn, error.
LOG_LEVEL=info
